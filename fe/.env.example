# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================

# API Configuration
# This points to your public backend URL. The port is not needed as Nginx handles it.
NEXT_PUBLIC_API_URL=https://skill-central-be.ccrolabs.com

# WebSocket Configuration
# Use the secure 'wss://' protocol and point to the public backend domain.
# The path is based on your backend's configuration.
NEXT_PUBLIC_WEBSOCKET_URL=wss://skill-central-be.ccrolabs.com/api/v1/notifications/ws/notifications
NEXT_PUBLIC_WS_URL=wss://skill-central-be.ccrolabs.com/api/v1/notifications/ws/notifications

# Application Settings
# Set to 'production' for performance and security optimizations.
NODE_ENV=production