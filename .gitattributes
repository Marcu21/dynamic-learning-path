# .gitattributes
# Ensure consistent line endings across different operating systems

# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts
*.sh text eol=lf

# Force LF line endings for Python files
*.py text eol=lf

# Force LF line endings for configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Force LF line endings for Docker files
Dockerfile text eol=lf
.dockerignore text eol=lf

# Binary files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
