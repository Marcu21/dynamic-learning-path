# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="DynamicLearningPath"

ENVIRONMENT="development"

# =============================================================================
# SERVER SETTINGS
# =============================================================================
SERVER_URL="http://localhost:3000"

# =============================================================================
# AUTHENTICATION SETTINGS
# =============================================================================
SECRET_KEY="your-secret-key-here-generate-a-new-one"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1000

# SendGrid Email Settings
SENDGRID_API_KEY="your-sendgrid-api-key-here"
FROM_EMAIL="noreply@yourdomain.com"

# Frontend URL for magic links
FRONTEND_URL="http://localhost:3000"

# Accepted email domains (comma-separated)
ACCEPTED_EMAILS="@computacenter.com"

# SSL Settings for development (set to false to disable SSL verification)
VERIFY_SSL="true"

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
LLM_URL="https://lmstudio.ccrolabs.com/v1"

LLM_MODEL="gemma-3-27b-it-qat"

LLM_API_KEY="your-llm-api-key"

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_URL="sqlite:///./dlp.db"
# For PostgreSQL use: postgresql://user:password@localhost/dbname

# =============================================================================
# PLATFORM SERVICE KEYS
# =============================================================================
YOUTUBE_API_KEY="your-youtube-api-key"

SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

COURSERA_API_KEY="your-coursera-api-key"
COURSERA_CLIENT_SECRET="your-coursera-client-secret"
COURSERA_APP_ID="your-coursera-app-id"

# =============================================================================
# OPTIONAL: PRODUCTION DEPLOYMENT
# =============================================================================
# ENVIRONMENT="production"
# ALLOWED_HOSTS="yourdomain.com,www.yourdomain.com"
